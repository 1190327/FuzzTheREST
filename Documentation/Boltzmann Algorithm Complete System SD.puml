@startuml
actor User
participant "QLearningAgent" as Agent
participant "APIFuzzyTestingEnvironment" as Environment
participant "Mutation Methods" as Mutations
participant "Reports/Charts" as Reports
participant "API Server" as APIServer
participant "Crash/Hang Tracker" as Tracker

== Training Phase ==
activate User

User -> Agent : initialize(env, mutation_methods, params)
activate Agent
Agent -> Environment : reset()
activate Environment
Environment --> Agent : initial_state
deactivate Environment

loop For each episode (train)
    Agent -> Agent : choose_action(state)\n(using Epsilon-Greedy exploration)
    Agent -> Mutations : select mutation per data type
    activate Mutations
    Mutations --> Agent : mutation methods
    deactivate Mutations

    Agent -> Environment : step(action, request_logs, crashes, hangs)
    activate Environment

    Environment -> Environment : fill_values(function, mutation_methods, ids)
    loop While response is string (retry fill_values)
        Environment -> Environment : retry fill_values
    end

    Environment -> APIServer : _execute_action(request)
    activate APIServer
    alt API responds OK
        APIServer --> Environment : valid response
    else API error or timeout
        APIServer --> Environment : error
        deactivate APIServer
        Environment -> Tracker : log_and_track_crash_or_hang(exception, function)
        activate Tracker
        Tracker -> Environment : response
        deactivate Tracker
    end

    Environment -> Environment : _update_environment_state(requests_log)
    Environment -> Environment : _calculate_reward()

    Environment --> Agent : new_state, reward, done
    deactivate Environment

    Agent -> Agent : update_q_table(state, action, reward, new_state)
    Agent -> Agent : log mutation usage and rewards
    Agent -> Agent : update temperature (decay)

    alt if done
        Agent -> Environment : break episode
        activate Environment
        Environment -> Agent : response
        deactivate Environment
    end
end

Agent -> Agent : record rewards, durations, Q-value snapshots
deactivate Agent

== Testing Phase ==

User -> Agent : test(request_logs, crashes, hangs)
activate Agent
Agent -> Environment : reset()
activate Environment
Environment --> Agent : initial_state
deactivate Environment

loop For each test episode
    Agent -> Agent : choose best action\n(argmax on Q-tables)
    Agent -> Environment : step(action, request_logs, crashes, hangs)
    activate Environment
    Environment -> APIServer : _execute_action(request)
    activate APIServer
    APIServer --> Environment : response
    deactivate APIServer
    Environment --> Agent : new_state, reward, done
    deactivate Environment

    Agent -> User : render environment state
end
deactivate Agent

== Reporting Phase ==

User -> Agent : write_agent_report(name)
activate Agent
Agent -> Reports : generate serialized report
activate Reports
Reports --> Agent : serialized data
deactivate Reports
Agent --> User : report ready
deactivate Agent

== Visualization Phase ==

User -> Agent : plot_cumulative_rewards()
activate Agent
Agent --> User : cumulative rewards plot
deactivate Agent

User -> Agent : plot_learning_curve()
activate Agent
Agent --> User : learning curve plot
deactivate Agent

User -> Agent : plot_q_value_convergence()
activate Agent
Agent --> User : Q-value convergence plot
deactivate Agent

User -> Agent : plot_action_distribution()
activate Agent
Agent --> User : action distribution plots
deactivate Agent

User -> Agent : plot_exploration_exploitation_ratio()
activate Agent
Agent --> User : exploration vs exploitation plot
deactivate Agent

User -> Agent : plot_state_visits()
activate Agent
Agent --> User : state visit distribution
deactivate Agent
deactivate User


@enduml
